# Neon PostgreSQL Database
DATABASE_URL="your_neon_database_url_here"
DIRECT_URL="your_neon_database_direct_url_here"

# Prisma Client
SEED_USER_EMAIL="your_email@gmail.com"

# Auth.js Secrets
AUTH_SECRET="generate_via_openssl_rand_base64_33"
AUTH_GITHUB_ID="your_github_oauth_client_id"
AUTH_GITHUB_SECRET="your_github_oauth_client_secret"

# Phase 2: secret-at-rest encryption for Organization.webhookSecret
ENCRYPTION_KEY="your_32_character_encryption_key_here"

# Phase 3: Durable Agent Orchestration (Upstash Workflow)
QSTASH_URL="your_qstash_url_here"
QSTASH_TOKEN="your_qstash_token_here"
QSTASH_CURRENT_SIGNING_KEY="your_qstash_current_signing_key_here"
QSTASH_NEXT_SIGNING_KEY="your_qstash_next_signing_key_here"

# Phase 3: AI / Stochastic Reasoning Layer
ANTHROPIC_API_KEY="your_anthropic_api_key_here"

# Future Phases
UPSTASH_REDIS_REST_URL="your_upstash_redis_url_here"
UPSTASH_REDIS_REST_TOKEN="your_upstash_redis_token_here"
OPENAI_API_KEY="your_openai_api_key_here"