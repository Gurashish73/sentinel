datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

// ─────────────────────────────────────────────────────────────────────────────
// AUTH.JS V5 REQUIRED MODELS (Prisma Adapter Contract)
// ─────────────────────────────────────────────────────────────────────────────
// These models satisfy the structural interface required by @auth/prisma-adapter.
// Modifications to core fields will break session handling and OAuth flows.
// ─────────────────────────────────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())

  accounts    Account[]
  sessions    Session[]
  memberships Membership[]
}

// ─────────────────────────────────────────────────────────────────────────────
// SENTINEL DOMAIN MODELS
// ─────────────────────────────────────────────────────────────────────────────
// Core business architecture supporting multi-tenancy, immutable event logging,
// and role-based operational tracking.
// ─────────────────────────────────────────────────────────────────────────────

enum Role {
  COMMANDER // Full administrative control: mutates org rules and gates agent actions
  ENGINEER  // Operational access: creates/views incidents and appends context
  OBSERVER  // Read-only system audit access
}

model Organization {
  id    String @id @default(cuid())
  name  String
  slug  String @unique

  // Data Security Requirement: Encrypted at rest via AES-256-GCM prior to write.
  // Never expose raw strings inside these fields in application code.
  webhookSecret String? @db.Text
  githubToken   String? @db.Text

  createdAt DateTime @default(now())

  memberships Membership[]
  incidents   Incident[]
  events      Event[]
  runbooks    Runbook[]
}

model Membership {
  id     String @id @default(cuid())
  role   Role   @default(ENGINEER)
  userId String
  orgId  String

  user User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  org  Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  // Tenant Isolation Boundary
  @@unique([userId, orgId])
  @@index([orgId])
}

enum IncidentStatus {
  OPEN
  INVESTIGATING     // Active autonomous agent workflow iteration execution
  AWAITING_APPROVAL // Human-in-the-loop interlock block: agent payload pending approval
  RESOLVED
}

enum Severity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model Incident {
  id          String         @id @default(cuid())
  orgId       String
  title       String
  description String?
  severity    Severity       @default(MEDIUM)
  status      IncidentStatus @default(OPEN)
  workflowRunId String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  org    Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  events Event[]

  // Fast dashboard queries gating tenant segregation and tracking states
  @@index([orgId, status])
}

model Event {
  id         String   @id @default(cuid())
  orgId      String
  incidentId String?
  type       String   // Shares exact structural naming convention with AgentEventType
  payload    Json
  actorId    String?  // Null denotes automated agent attribution execution context
  externalId String?  // Webhook message delivery trace ID mapping (e.g. X-GitHub-Delivery)
  createdAt  DateTime @default(now())

  org      Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  incident Incident?    @relation(fields: [incidentId], references: [id], onDelete: Cascade)

  // IDEMPOTENCY GUARD: Nullable externalId handling inside Postgres unique index. 
  // Standard non-webhook rows (NULL) skip valuation loops; matching (orgId, externalId)
  // structures trigger immediate P2002 catches to protect against duplicate pipeline processing.
  @@unique([orgId, externalId])
  @@index([orgId, incidentId])
  @@index([orgId, type])
}

model Runbook {
  id        String   @id @default(cuid())
  orgId     String
  title     String
  content   String   @db.Text
  createdAt DateTime @default(now())

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
}